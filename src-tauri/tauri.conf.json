{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lookback",
  "version": "0.1.0",
  "identifier": "app.lookback.tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Lookback",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 640,
        "titleBarStyle": "Visible",
        "hiddenTitle": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "externalBin": [
      "bin/all-in-one",
      "bin/front",
      "bin/conductor-main",
      "bin/memories-import",
      "bin/protoc"
    ],
    "resources": {
      "../workers/": "workers/",
      "../dict/": "dict/"
    }
  }
}
