# Node
node_modules/
dist/
.vite/

# Rust
/target/
src-tauri/target/
src-tauri/gen/schemas/

# Tauri build artifacts
src-tauri/sidecar-bin/
*.dylib

# Bundled sidecar binaries (large; built from sibling jobworkerp/memories
# repos and copied in with the platform-triple suffix before `tauri build`).
# See README for the build/copy procedure. Not committed.
src-tauri/bin/
src-tauri/plugins/

# Local data / logs
log/
*.log
*.sqlite3*

# Real-machine debug capture (e.g. a sampled WorkflowResult dumped during
# manual verification). Scratch only — never committed.
/test.json

# IDE
.idea/
.vscode/

# OS
.DS_Store

# build.rs generates proto code into OUT_DIR (not committed).
# `src-tauri/src/grpc/proto/mod.rs` is hand-written and IS committed.

/.claude/

# Dependency build trees cloned by scripts/build-release.sh.
/.build-deps/

# The lindera IPADIC dictionary is generated at build time by
# scripts/build-release.sh (lindera 0.44.1 CLI), which also stages the matching
# COPYING license from the IPADIC source. Nothing under here is committed — the
# license is sourced with the dictionary so it always matches the built kind.
/dict/lindera/
/dict
/ops/*


/specs

